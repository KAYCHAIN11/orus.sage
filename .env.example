# Trinity Configuration
TRINITY_MODE=trinity_native
TRINITY_PRIMARY_MODE=trinity_native
TRINITY_FALLBACK_ENABLED=true
TRINITY_HEALTH_CHECK_INTERVAL=30000
TRINITY_LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/orus_sage
REDIS_URL=redis://localhost:6379

# API Configuration
API_PORT=3001
API_HOST=0.0.0.0
API_TIMEOUT=10000

# Development
NODE_ENV=development
DEBUG=orus:*
